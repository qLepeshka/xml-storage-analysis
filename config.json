  "database_configs": {
    "postgresql": {
      "host": "localhost",
      "port": 5432,
      "database": "xml_test",
      "username": "postgres",
      "password": "password"
    },
    "mysql": {
      "host": "localhost",
      "port": 3306,
      "database": "xml_test",
      "username": "root",
      "password": "password"
    },
    "sqlite_demo": {
      "database_path": "demo_data.db",
      "description": "Демонстрационная база данных SQLite с тестовыми данными"
    }
  },
  "output_settings": {
    "results_file": "results/test_results.csv",
    "report_dir": "reports/",
    "visualization_dir": "visualizations/"

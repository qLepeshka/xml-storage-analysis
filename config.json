    "native_text",
    "normalized_relational",
    "xml_datatype",
    "hybrid"
  ],
  "operations": ["read", "write", "search"],
  "test_parameters": {
    "data_size": 50,
    "test_runs": 5,
    "warmup_runs": 2,
    "timeout": 30
